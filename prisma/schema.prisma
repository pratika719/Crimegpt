// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CaseStatus {
  OPEN
  UNDER_INVESTIGATION
  CLOSED
  ARCHIVED
}

enum DocumentType {
  FIR
  INVESTIGATION_SUMMARY
  CHARGE_SHEET
  LEGAL_ANALYSIS
  AI_DIAGNOSTICS
  REMAND_REQUEST
  CASE_DIARY
}

enum GeneratedDocumentStatus {
  DRAFT
  GENERATING
  COMPLETED
  FAILED
  ARCHIVED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum AIRequestStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum EvidenceProcessingStatus {
  NOT_STARTED
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AIRequestType {
  LEGAL_ANALYSIS
  FIR_GENERATION
  INVESTIGATION_SUMMARY
  CHARGE_SHEET
  CHAT
  AI_DIAGNOSTICS_GENERATION
  REMAND_REQUEST_GENERATION
  CASE_DIARY_GENERATION
}

model Case {
  id         String     @id @default(cuid())
  title      String
  narrative  String
  status     CaseStatus @default(OPEN)
  userId     String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  archivedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  generatedDocuments   GeneratedDocument[]
  chatSessions         ChatSession[]
  aiRequestLogs        AIRequestLog[]
  caseMetadata         CaseMetadata?
  activities           CaseActivity[]
  persons              Person[]
  evidence             Evidence[]
  checklistItems       ChecklistItem[]
  investigationProfile InvestigationProfile?
  victims              Victim[]
  accused              Accused[]
  witnesses            Witness[]
  vehicles             Vehicle[]
  seizedItems          SeizedItem[]
  medicalInformation   MedicalInformation[]
  courtInformation     CourtInformation[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([userId, status])
}

//
model GeneratedDocument {
  id             String                  @id @default(cuid())
  caseId         String
  type           DocumentType
  title          String
  content        Json
  version        Int                     @default(1)
  status         GeneratedDocumentStatus @default(COMPLETED)
  errorMessage   String?
  sourceSnapshot Json?
  generatedBy    String?
  generatedAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([caseId, type])
  @@index([caseId, type, version])
}

model ChatSession {
  id String @id @default(cuid())

  title String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  messages ChatMessage[]

  @@index([caseId])
}

model ChatMessage {
  id String @id @default(cuid())

  role MessageRole

  content String @db.Text

  createdAt DateTime @default(now())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model LegalChunk {
  id String @id @default(cuid())

  lawName     String
  sectionCode String
  title       String
  content     String @db.Text

  source String?

  createdAt DateTime @default(now())
}

model AIRequestLog {
  id               String          @id @default(cuid())
  caseId           String?
  userId           String
  requestType      AIRequestType
  status           AIRequestStatus @default(SUCCEEDED)
  prompt           String?
  retrievedContext String?
  response         String?
  modelUsed        String?
  tokenUsage       Json?
  latencyMs        Int?
  errorCode        String?
  errorMessage     String?
  retryCount       Int             @default(0)
  queueJobId       String?
  inputHash        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  startedAt        DateTime?
  completedAt      DateTime?

  case Case? @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([userId])
  @@index([requestType])
  @@index([status])
  @@index([createdAt])
  @@index([queueJobId])
  @@index([caseId, requestType])
  @@index([userId, createdAt])
}

model CaseMetadata {
  id                 String    @id @default(cuid())
  incidentDate       DateTime?
  incidentTime       String?
  incidentLocation   String?
  victimName         String?
  victimStatement    String?   @db.Text
  suspectName        String?
  suspectDescription String?   @db.Text
  witnessInformation String?   @db.Text
  evidenceSummary    String?   @db.Text
  officerNotes       String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  caseId String @unique
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

enum ActivityType {
  CASE_CREATED
  CASE_UPDATED
  METADATA_CREATED
  METADATA_UPDATED
  LEGAL_ANALYSIS_GENERATED
  FIR_GENERATED
  INVESTIGATION_SUMMARY_GENERATED
  CHARGE_SHEET_GENERATED
  REMAND_REQUEST_GENERATED
  CASE_DIARY_GENERATED
  DOCUMENT_DOWNLOADED
  DOCUMENT_REGENERATED
  AI_DIAGNOSTICS_GENERATED
  DOCUMENT_CREATED
  PERSON_ADDED
  PERSON_UPDATED
  PERSON_DELETED
  EVIDENCE_ADDED
  EVIDENCE_UPDATED
  EVIDENCE_DELETED
  CHECKLIST_ITEM_COMPLETED
  INVESTIGATION_PROFILE_UPDATED
  VICTIM_ADDED
  VICTIM_UPDATED
  VICTIM_DELETED
  ACCUSED_ADDED
  ACCUSED_UPDATED
  ACCUSED_DELETED
  WITNESS_ADDED
  WITNESS_UPDATED
  WITNESS_DELETED
  VEHICLE_ADDED
  VEHICLE_UPDATED
  VEHICLE_DELETED
  SEIZED_ITEM_ADDED
  SEIZED_ITEM_UPDATED
  SEIZED_ITEM_DELETED
  MEDICAL_INFO_ADDED
  MEDICAL_INFO_UPDATED
  MEDICAL_INFO_DELETED
  COURT_INFO_ADDED
  COURT_INFO_UPDATED
  COURT_INFO_DELETED
  DOCUMENT_RENAMED
  DOCUMENT_DELETED_SINGLE
  CHECKLIST_ITEM_RENAMED
  CHECKLIST_ITEM_DELETED
}

enum PersonRole {
  VICTIM
  SUSPECT
  WITNESS
  OFFICER
}

model Person {
  id        String     @id @default(cuid())
  name      String
  role      PersonRole
  phone     String?
  address   String?    @db.Text
  statement String?    @db.Text
  notes     String?    @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  victim  Victim?
  accused Accused?
  witness Witness?

  @@index([caseId])
  @@index([role])
  @@index([caseId, role])
}

model CaseActivity {
  id           String       @id @default(cuid())
  activityType ActivityType
  description  String       @db.Text
  metadata     Json?
  createdAt    DateTime     @default(now())

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([activityType])
  @@index([createdAt])
  @@index([caseId, createdAt])
}

enum EvidenceType {
  DOCUMENT
  IMAGE
  VIDEO
  AUDIO
  SCREENSHOT
  LOG_FILE
  OTHER
}

model Evidence {
  id               String                   @id @default(cuid())
  caseId           String
  title            String
  description      String?
  type             EvidenceType
  notes            String?
  fileUrl          String?
  mimeType         String?
  fileSizeBytes    Int?
  hashSha256       String?
  extractedText    String?
  processingStatus EvidenceProcessingStatus @default(NOT_STARTED)
  processingError  String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([type])
  @@index([processingStatus])
  @@index([hashSha256])
  @@index([caseId, type])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  title       String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([completed])
  @@index([caseId, completed])
}

model InvestigationProfile {
  id     String @id @default(cuid())
  caseId String @unique
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Police Information
  firNumber            String?
  policeStation        String?
  investigatingOfficer String?
  dateOfRegistration   DateTime?

  // Incident details
  incidentDateTime    DateTime?
  incidentLocation    String?
  incidentDescription String?   @db.Text

  // Notes
  investigationNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
}

model Victim {
  id            String   @id @default(cuid())
  caseId        String
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  personId      String   @unique
  person        Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  injuryDetails String?  @db.Text
  status        String? // e.g., Deceased, Injured, Stable, Unharmed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([caseId])
}

model Accused {
  id           String   @id @default(cuid())
  caseId       String
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  personId     String   @unique
  person       Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  arrestStatus String? // e.g., Absconding, Arrested, Custody, On Bail
  bailDetails  String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([caseId])
}

model Witness {
  id               String    @id @default(cuid())
  caseId           String
  case             Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  personId         String    @unique
  person           Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  statementDate    DateTime?
  credibilityScore String? // e.g., High, Medium, Low
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([caseId])
}

model Vehicle {
  id                String   @id @default(cuid())
  caseId            String
  case              Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  make              String?
  model             String?
  year              Int?
  color             String?
  licensePlate      String?
  registrationState String?
  ownerName         String?
  seizureStatus     String? // e.g., Seized, Released, Wanted
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([caseId])
  @@index([licensePlate])
}

model SeizedItem {
  id              String    @id @default(cuid())
  caseId          String
  case            Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  itemName        String
  description     String?   @db.Text
  serialNumber    String?
  seizureLocation String?
  seizureDate     DateTime?
  officerInCharge String?
  storageLocation String?
  status          String? // e.g., In Custody, Released, Destroyed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([caseId])
  @@index([status])
}

model MedicalInformation {
  id               String    @id @default(cuid())
  caseId           String
  case             Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  hospitalName     String?
  doctorName       String?
  admissionDate    DateTime?
  injuryType       String?
  medicalReportNo  String?
  treatmentDetails String?   @db.Text
  severity         String? // e.g., Critical, Severe, Moderate, Mild
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([caseId])
  @@index([severity])
}

model CourtInformation {
  id                   String    @id @default(cuid())
  caseId               String
  case                 Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  courtName            String?
  judgeName            String?
  caseNumber           String?
  nextHearingDate      DateTime?
  chargesheetFiledDate DateTime?
  currentStatus        String? // e.g., Trial, Hearing, Disposed
  judgementDetails     String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([caseId])
  @@index([nextHearingDate])
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  cases         Case[]
  aiRequestLogs AIRequestLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
